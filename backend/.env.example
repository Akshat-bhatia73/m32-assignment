# ---- Database (Neon Postgres) ----
# Use the pooled connection string from Neon, psycopg (v3) driver.
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- LLM provider ----
# LLM_PROVIDER: gemini (default, free) | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Google OAuth (Phase 4 bonus) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Composio (Phase 3) ----
COMPOSIO_API_KEY=

# ---- CORS / cookies ----
# Comma-separated list of allowed frontend origins.
FRONTEND_ORIGIN=http://localhost:5173
# Set to "none" + secure cookies in production (cross-site); "lax" for local dev.
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
