# Root env for `docker compose`. Copy to `.env` (gitignored) and fill in as needed.
# Every value has a default in docker-compose.yml — the stack runs even if this file is empty.

# ---- Local Postgres (used by the `db` service) ----
POSTGRES_USER=m32
POSTGRES_PASSWORD=m32
POSTGRES_DB=m32

# ---- Database the backend connects to ----
# Leave unset to use the local `db` container above.
# To use Neon instead, paste your pooled connection string and swap the driver to psycopg:
#   postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
# DATABASE_URL=postgresql+psycopg://...

# ---- Auth ----
JWT_SECRET=dev-insecure-secret-change-me

# ---- LLM (leave blank to run chat in echo mode) ----
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
OPENAI_API_KEY=

# ---- Google OAuth (Phase 4) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Composio (Phase 3) ----
COMPOSIO_API_KEY=

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:5173
